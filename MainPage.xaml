<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="GanoHesaplama.MainPage">

    <VerticalStackLayout>

        <CollectionView x:Name="dersListesi">

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="10" ColumnDefinitions="*,*,*">
                        <Label Text="{Binding DersAdi}" />
                        <Label Grid.Column="1" Text="{Binding HarfNotu}" />
                        <Label Grid.Column="2" Text="{Binding AKTS}" />
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

        <Label
            x:Name="ganoLabel"
            FontSize="20"
            HorizontalOptions="Center"/>

    </VerticalStackLayout>

</ContentPage>